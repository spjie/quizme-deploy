{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/save",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/update/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/open/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/list-jsons",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/delete/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/chat/stream",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/chat",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/health",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}